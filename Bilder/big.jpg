    <script>

        document.addEventListener("DOMContentLoaded", () => {
            const scroll_to_top = document.getElementById("scroll_to_top");
            
            // Show button when scrolling down
            window.addEventListener("scroll", () => {
                if (window.scrollY > 200) {
                    scroll_to_top.style.display = "block";
                } else {
                    scroll_to_top.style.display = "none";
                }
            });

            // Scroll to top when clicked
            scroll_to_top.addEventListener("click", () => {
                window.scrollTo({
                top: 0,
                behavior: "smooth"
                });
            });
        });


        function downloadContent(image_server, content_id, content_file_type) {
            // Construct the download URL. Adjust this according to your URL scheme.
            var downloadUrl = 'https://initiate.alphacoders.com' + '/download/' + image_server + '/' + content_id + '/' + content_file_type;

            // Create a temporary link element
            var tempLink = document.createElement('a');
            tempLink.href = downloadUrl;
            tempLink.setAttribute('download', ''); // This can prompt download depending on content type and browser support
            tempLink.style.display = 'none';

            // Append to the document and trigger the download
            document.body.appendChild(tempLink);
            tempLink.click();

            // Clean up by removing the temporary link
            document.body.removeChild(tempLink);
        }

        function downloadContentModal(image_server, legacy_content_id, content_file_type, content_table_entry_id) {
            //return downloadContent(image_server, content_id, content_file_type);
            // Construct the download URL. Adjust this according to your URL scheme.
            var downloadUrl = 'https://initiate.alphacoders.com' + '/download/' + image_server + '/' + legacy_content_id + '/' + content_file_type;

            // Show modal with countdown
            showDownloadModal(downloadUrl, content_table_entry_id);
        }

        function showDownloadModal(downloadUrl, content_table_entry_id) {
            let modal_url = "https://initiate.alphacoders.com/download/modal/" + content_table_entry_id;

			fetch(modal_url, {
				credentials: 'same-origin',
				headers: {
					'X-Requested-With': 'XMLHttpRequest',
				},
			})
			.then(function(response) {
				if(!response.ok) {
					throw new Error('Unable to load download modal');
				}

				return response.text();
			})
			.then(function(data) {
				// Insert the modal HTML from the server
				const wrapper = document.createElement('div');
				wrapper.innerHTML = data;

				while(wrapper.firstChild) {
					document.body.appendChild(wrapper.firstChild);
				}

				// Run script tags from injected modal content (needed for ad initialization)
				const modal = document.getElementById('downloadModal');
				if(modal) {
					const modal_scripts = modal.querySelectorAll('script');
					modal_scripts.forEach(function(old_script) {
						const new_script = document.createElement('script');

						for(let i = 0; i < old_script.attributes.length; i++) {
							const attribute = old_script.attributes[i];
							new_script.setAttribute(attribute.name, attribute.value);
						}

						if(old_script.textContent) {
							new_script.textContent = old_script.textContent;
						}

						old_script.parentNode.replaceChild(new_script, old_script);
					});
				}

				// Now set up the modal functionality
				setupModalFunctionality(downloadUrl, content_table_entry_id);
			})
			.catch(function() {
				showNotice('error', 'Unable to load download modal');
			});
        }

        function setupModalFunctionality(downloadUrl, content_table_entry_id) {
                        var countdown = 5;
            
            if(content_table_entry_id == 3581636) {
                countdown = 120;
            }

            var countdownElement = document.getElementById('countdown');
            var modal = document.getElementById('downloadModal');
            var cancelBtn = document.getElementById('cancelDownload');
            var downloadNowBtn = document.getElementById('downloadNow');

            // Update countdown display
            function updateCountdown() {
                countdownElement.textContent = countdown;
                if (countdown <= 0) {
                    executeDownload(downloadUrl);
                    closeModal();
                } else {
                    countdown--;
                    setTimeout(updateCountdown, 1000);
                }
            }

            // Execute the actual download
            function executeDownload(url) {
                var tempLink = document.createElement('a');
                tempLink.href = url;
                tempLink.setAttribute('download', '');
                tempLink.style.display = 'none';
                document.body.appendChild(tempLink);
                tempLink.click();
                document.body.removeChild(tempLink);
            }

            // Close modal
            function closeModal() {
                if (modal && modal.parentNode) {
                    modal.parentNode.removeChild(modal);
                }
            }

            // Event listeners
            cancelBtn.addEventListener('click', closeModal);
            
            // Make modal dismissible by clicking outside of it
            document.addEventListener('click', function(e) {
                if (modal && !modal.contains(e.target)) {
                    closeModal();
                }
            });

            // Start countdown
            updateCountdown();
        }


        async function interactSite(content_type, content_id, user_interaction, page_type = "") {

            url = "https://api.alphacoders.com/site/interact";

            data = {
                content_type: content_type,
                content_id: content_id,
                user_interaction: user_interaction,
                page_type: page_type
                
            }

            
            response = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            });

            if(!response.ok) {
                const message = `Error ${response.status}: ${response.statusText}`;
                showNotice('error', message);
                return;
            }

            response_data = await response.json();

            interaction_element = document.getElementById(`${content_type}_${content_id}_${user_interaction}`);

            if(response_data.hasOwnProperty('success') && response_data.success == true) {

                /*
                if(response_data.hasOwnProperty('is_favorite') && response_data.is_favorite == true) {
                    favorite_tag_button.textContent = "A Favorite!";
                } else {
                    favorite_tag_button.textContent = "Favorite";
                }
                */

                if(user_interaction == 'down') {
                    interaction_element.innerHTML = '<img class="svg svg-black" src="https://static.alphacoders.com/fontawesome-pro-5.15.4-web/svgs/solid/sad-tear.svg">';
                } else if(user_interaction == 'favorite' && content_type == 'tag' && response_data.hasOwnProperty('removed') && response_data.removed == true) {


                    showNotice('success', 'Favorite Removed');

                    let favorite_wrapper_div = document.getElementById(`tag_${content_id}_favorite_wrapper`);
                    let new_html = `
                        <span class='button button-favorite' 
                            title="Favorite This"
                            onclick="interactSite('tag', ${content_id}, 'favorite'); return false;"
                            id="tag_${content_id}_favorite">
                            <img class="svg svg-black" alt="Favorite Icon" src="https://static.alphacoders.com/fontawesome-pro-5.15.4-web/svgs/solid/star.svg"> 
                            Favorite
                        </span>
                    `;
                    favorite_wrapper_div.innerHTML = new_html;

                } else if(user_interaction == 'favorite' && content_type == 'tag') {


                                            showNotice('success', 'Thanks for the feedback! Login or register to save your favorites!');
                    
                    
                } 
                else if(user_interaction == "favorite" && response_data.hasOwnProperty('removed') && response_data.removed == true && 
                    content_type == "content" && response_data.page_type == "content_view") {

                        let favorite_wrapper_div = document.getElementById(`favorite_${content_id}`);

                        let new_html = `
                            <span class='button button-favorite' 
                                title="Favorite This"
                                onclick="interactSite('content', ${content_id}, 'favorite', 'content_view'); return false;"
                                id="content_${content_id}_favorite">
                                <img class="svg svg-black" alt="Favorite Icon" src="https://static.alphacoders.com/fontawesome-pro-5.15.4-web/svgs/solid/heart.svg"> 
                                ${response_data.favorites}&nbsp;Favorite
                            </span>
                        `;

                        favorite_wrapper_div.innerHTML = new_html;
                        
                       
                    }
                else if(user_interaction == "favorite" && content_type == "content" && response_data.page_type == "content_view") {

                    
                                      
                }
                // Non tag favorites - like a piece of content!
                else if(user_interaction == 'favorite') {

                    showNotice('success', 'Favorite Added!');
                    interaction_element.textContent = "A Favorite!";

                } else if(user_interaction == "more") {
                    interaction_element.innerHTML = "We're On It!";
                    more_message_element = document.getElementById(`more_message`);
                    more_message_element.innerHTML = 'You can see what the community is most requesting <a href="https://alphacoders.com/contest">at our community page</a>';
                } 
                // Removed like on content view page
                else if(user_interaction == "up" && response_data.hasOwnProperty('removed') && response_data.removed == true && 
                    content_type == "content" && response_data.page_type == "content_view") {

                    let rate_wrapper_div = document.getElementById(`rate_${content_id}`);

                    let new_html = `
                        <span class='button button-green rate-content' 
                            title="Like This"
                            onclick="interactSite('content', ${content_id}, 'up', 'content_view'); return false;"
                            id="content_${content_id}_up">
                            <img    class="svg svg-black" 
                                    alt="Like Icon" 
                                    src="https://static.alphacoders.com/fontawesome-pro-5.15.4-web/svgs/solid/thumbs-up.svg"> 
                                    ${response_data.votes_up}&nbsp;Like
                        </span>
                    `;

                    rate_wrapper_div.innerHTML = new_html;
                }
                // Like on content view page
                else if(user_interaction == "up" && content_type == "content" && response_data.page_type == "content_view") {
                    console.log("Rated up on content view page");
                    let rate_wrapper_div = document.getElementById(`rate_${content_id}`);

                                            let new_html = `
                            <img class="svg svg-black" src="https://static.alphacoders.com/fontawesome-pro-5.15.4-web/svgs/solid/smile-beam.svg"> 
                            <img class="svg svg-black" src="https://static.alphacoders.com/fontawesome-pro-5.15.4-web/svgs/solid/thumbs-up.svg"> 
                            ${response_data.votes_up}
                        `;

                        interaction_element.innerHTML = new_html;
                                     

                } else if(user_interaction == 'up') {

                    let new_html = `
                        <img class="svg svg-black" src="https://static.alphacoders.com/fontawesome-pro-5.15.4-web/svgs/solid/smile-beam.svg"> 
                        <img class="svg svg-black" src="https://static.alphacoders.com/fontawesome-pro-5.15.4-web/svgs/solid/thumbs-up.svg"> 
                        ${response_data.votes_up}
                    `;

                    interaction_element.innerHTML = new_html;
                }
                
            } else {
                if(response_data.hasOwnProperty('error')) {
                    showNotice('error', response_data.error);
                } else {
                    showNotice('error', 'Unknown error');
                }

            }
        }

        function hideNotice() {
            const notice = document.getElementById('notice');

            // Fade out the notice
            notice.style.opacity = '0';

            // Actually hide the notice after the fade-out transition is complete
            setTimeout(() => notice.className = 'notice', 500);
        }

        function showNotice(notice_type, notice_message) {

            const notice = document.getElementById('notice');
            notice.style.opacity = '100';
            const notice_close_button = document.getElementById('notice-close');
            const messageElement = document.getElementById('notice-message');

            messageElement.innerHTML = notice_message;

            if(notice_type == 'success') {

                notice.className = 'notice-visible notice-success';
                notice_close_button.className = 'notice-close notice-close-success';
  
              
            } else if(notice_type == 'error') {
                notice.className = 'notice-visible notice-error';
                notice_close_button.className = 'notice-close notice-close-error';
            }

            // Automatically hide the notice after 4 seconds
            setTimeout(hideNotice, 4000);

        }

        function toggleMenu() {

            var header_menu = document.querySelector('div.header-menu');
            var header_menu_display_style = window.getComputedStyle(header_menu).display;

            // SHOW IT
            if(header_menu_display_style == 'none' || header_menu_display_style == '' || header_menu_display_style == false) {

                header_menu.style.display = 'flex';
            } 
            // HIDE IT
            else {
                header_menu.style.display = 'none';

            }
            
        }


        // Theme Toggle
        (function() {
            var svg_base = "https://static.alphacoders.com/fontawesome-pro-5.15.4-web/svgs";
            var theme_icons = {
                'dark': svg_base + '/solid/moon.svg',
                'light': svg_base + '/solid/sun.svg'
            };
            var default_icon = svg_base + '/solid/adjust.svg';
            var toggle_btn = document.getElementById('theme-toggle-btn');
            var dropdown = document.getElementById('theme-toggle-dropdown');

            function resolveSystemTheme() {
                if (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches) {
                    return 'light';
                }
                return 'dark';
            }

            function getCookie(name) {
                var value = '; ' + document.cookie;
                var parts = value.split('; ' + name + '=');
                if (parts.length === 2) {
                    return parts.pop().split(';').shift();
                }
                return null;
            }

            function setThemePreference(choice) {
                try {
                    localStorage.setItem('theme', choice);
                } catch (e) {
                }

                var max_age = 60 * 60 * 24 * 365 * 5;
                var cookie = 'theme=' + encodeURIComponent(choice) + '; Max-Age=' + max_age + '; Path=/; SameSite=Lax';
                var host = window.location.hostname;
                if (host && host.indexOf('.') !== -1) {
                    var parts = host.split('.');
                    if (parts.length >= 2) {
                        var base_domain = parts.slice(-2).join('.');
                        cookie += '; Domain=.' + base_domain;
                    }
                }
                document.cookie = cookie;
            }

            function getStoredTheme() {
                var cookie_theme = getCookie('theme');
                if (cookie_theme) {
                    return cookie_theme;
                }

                try {
                    return localStorage.getItem('theme');
                } catch (e) {
                    return null;
                }
            }

            function applyTheme(choice) {
                var effective = choice;
                if (choice === 'system' || !choice) {
                    effective = resolveSystemTheme();
                }
                document.documentElement.setAttribute('data-theme', effective);

                if (toggle_btn) {
                    if (choice && theme_icons[choice]) {
                        toggle_btn.src = theme_icons[choice];
                    } else {
                        toggle_btn.src = default_icon;
                    }
                }

                var options = document.querySelectorAll('.theme-toggle-option');
                for (var i = 0; i < options.length; i++) {
                    var opt = options[i];
                    if (opt.getAttribute('data-theme-value') === choice) {
                        opt.classList.add('active');
                    } else {
                        opt.classList.remove('active');
                    }
                }
            }

            var stored_theme = getStoredTheme();
            applyTheme(stored_theme || 'system');

            if (toggle_btn && dropdown) {
                toggle_btn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    dropdown.classList.toggle('show');
                });

                var options = dropdown.querySelectorAll('.theme-toggle-option');
                for (var i = 0; i < options.length; i++) {
                    options[i].addEventListener('click', function(e) {
                        var choice = this.getAttribute('data-theme-value');
                        setThemePreference(choice);
                        applyTheme(choice);
                        dropdown.classList.remove('show');
                    });
                }

                document.addEventListener('click', function(e) {
                    if (!toggle_btn.contains(e.target) && !dropdown.contains(e.target)) {
                        dropdown.classList.remove('show');
                    }
                });
            }

            if (window.matchMedia) {
                window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function() {
                    var current = getStoredTheme();
                    if (!current || current === 'system') {
                        applyTheme('system');
                    }
                });
            }
        })();


        function authorFilter(author_id, filter_type, new_tab = false) {
            const form = document.createElement("form");
            form.method = "POST";
            form.action = "https://alphacoders.com/author/view/" + author_id;
            if(new_tab == true) {
                form.target = "_blank";
            }
            
            const hidden_field = document.createElement("input");
            hidden_field.type = "hidden";
            hidden_field.name = "filter";
            hidden_field.value = filter_type;
            
            form.appendChild(hidden_field);
            document.body.appendChild(form);
            
            form.submit();
        }

        function profileFilter(profile_user_id, profile_user_name, filter_type) {
            const form = document.createElement("form");
            form.method = "POST";
            form.action = "https://alphacoders.com/users/profile/" + profile_user_id + "/" + encodeURIComponent(profile_user_name);
            
            const hidden_field = document.createElement("input");
            hidden_field.type = "hidden";
            hidden_field.name = "filter";
            hidden_field.value = filter_type;
            
            form.appendChild(hidden_field);
            document.body.appendChild(form);
            
            form.submit();
        }


    </script>

    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const dropdownButton = document.querySelector('.button-dropdown');
            const dropdownContent = document.querySelector('.button-dropdown-content');
        
            if(dropdownButton && dropdownContent) {
                dropdownButton.addEventListener('click', function(e) {
                    e.preventDefault();
                    dropdownContent.classList.toggle('show');
                });
            
                // Close the dropdown when clicking outside of it
                document.addEventListener('click', function(e) {
                    if (!dropdownButton.contains(e.target) && !dropdownContent.contains(e.target)) {
                        dropdownContent.classList.remove('show');
                    }
                });
            }
           
        });
    </script>

    
    <script>

                
        async function copyShareText(text_to_copy) {

            const helper_note = document.getElementById("helping_note");
            let copy_result = false;
            let textarea = null;

            if (navigator.clipboard && navigator.clipboard.writeText) {
                try {
                    await navigator.clipboard.writeText(text_to_copy);
                    copy_result = true;
                }
                catch (error) {
                    copy_result = false;
                }
            }

            if(copy_result == false) {
                textarea = document.createElement('textarea');
                textarea.value = text_to_copy;
                textarea.style.position = 'fixed';
                textarea.style.opacity = '0';
                document.body.appendChild(textarea);
                textarea.focus();
                textarea.select();

                try {
                    copy_result = document.execCommand('copy');
                }
                catch (error) {
                    copy_result = false;
                }

                document.body.removeChild(textarea);
            }

            if(copy_result) {
                helper_note.textContent = 'Copied to clipboard.';
                return;
            }

            helper_note.textContent = 'Unable to auto copy. Please copy manually.';
        }

        async function calendarContent(content_id) {

            let calendar_button_element = document.getElementById("content_calendar_button");
            calendar_button_element.textContent = "Preparing Calendar...";

            let url = `https://initiate.alphacoders.com/content-request/add`;

            data = {
                content_id: content_id,
                content_request_type: 'calendar'
            }

            
            response = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            });

            if(!response.ok) {
                const message = `Error ${response.status}: ${response.statusText}`;
                showNotice('error', message);
                return;
            }

            response_data = await response.json();

            if(response_data.hasOwnProperty('success') && response_data.success == true) {

                const form = document.createElement('form');
                form.method = 'POST';
                form.action = "https://initiate.alphacoders.com/tool/calendar";

                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'content_request_id';
                input.value = response_data.content_request_id;

                form.appendChild(input);
                document.body.appendChild(form);
                form.submit();

            } else {

                calendar_button_element.textContent = "Unable To Add Calendar";
                if(response_data.hasOwnProperty('error')) {
                    showNotice('error', response_data.error);
                } else {
                    showNotice('error', 'Unknown error');
                }

            }

        }

        async function cropContent(content_id) {

            let crop_button_element = document.getElementById("content_crop_button");
            crop_button_element.textContent = "Preparing For Crop/Customize";


            let url = `https://initiate.alphacoders.com/content-request/add`;

            data = {
                content_id: content_id,
                content_request_type: 'crop'
            }

            
            response = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            });

            if(!response.ok) {
                const message = `Error ${response.status}: ${response.statusText}`;
                showNotice('error', message);
                return;
            }

            response_data = await response.json();


            // We can do to the crop image request page
            if(response_data.hasOwnProperty('success') && response_data.success == true) {

                const form = document.createElement('form');
                form.method = 'POST';
                form.action = "https://initiate.alphacoders.com/tool/crop-image";

                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'content_request_id';
                input.value = response_data.content_request_id;

                form.appendChild(input);
                document.body.appendChild(form);
                form.submit();


            } else {

                crop_button_element.textContent = "Unable To Crop";
                if(response_data.hasOwnProperty('error')) {
                    showNotice('error', response_data.error);
                } else {
                    showNotice('error', 'Unknown error');
                }

            }

        }

    </script>


    

