        <script>
			let page = 1;
			let is_loading = false;
			let no_more_results = false;
			// ? or & based on if there's already content in the query bit of the url
							const next_url_params = "?";
			
			function appendHtmlBeforeEndOfContent(html_string) {
				const end_of_content = document.getElementById('end_of_content');

				if(!end_of_content) {
					return;
				}

				const container = document.createElement('div');
				container.innerHTML = html_string;

				while(container.firstChild) {
					end_of_content.parentNode.insertBefore(container.firstChild, end_of_content);
				}
			}

			function getEndOfContentTop() {
				const end_of_content = document.getElementById('end_of_content');

				if(!end_of_content) {
					return 0;
				}

				const rect = end_of_content.getBoundingClientRect();
				return rect.top + window.scrollY;
			}

			async function loadNextPage() {
				page++;

									// Break up the url a little bit so things like Google mostly see the base page URL
					const url = "https://api.alphacoders.com" + "/content/rel" + "ated/3221402" + next_url_params + "page=" + page + "&quickload=1";
				
				try {
					const response = await fetch(url, {
						credentials: 'same-origin',
						headers: {
							'X-Requested-With': 'XMLHttpRequest',
						},
					});

					if(!response.ok) {
						throw new Error("Infinite scroll request failed");
					}

					const html_string = await response.text();
					appendHtmlBeforeEndOfContent(html_string);

					// Check to see if we have an element with id="no_more_results"
					let no_more_results_element = document.getElementById('no_more_results');
					if(no_more_results_element) {
						no_more_results = true;
					}
				} catch (e) {
					no_more_results = true;
				} finally {
					setTimeout(function () {
						is_loading = false;
					}, 1000);
				}
			}

			document.addEventListener("DOMContentLoaded", function () {
				window.addEventListener('scroll', function () {
					if(no_more_results) {
						return;
					}

					if(is_loading) {
						return;
					}

					const scroll_pos = window.scrollY;
					const end_of_content_top = getEndOfContentTop();
					const window_height = window.innerHeight || document.documentElement.clientHeight;

					// Load next page
					if(scroll_pos >= (end_of_content_top - window_height - 800) && scroll_pos < (end_of_content_top + 200)) {
						is_loading = true;
						loadNextPage();
					}
				});
			});
        </script>
    

</body>

</html>